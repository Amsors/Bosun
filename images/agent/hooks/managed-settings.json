{
  "allowManagedHooksOnly": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/bosun/hooks/session-start",
            "args": [],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
